function nroDeBolitasDeColor_ADistancia_Al(color, unaDistancia, direccion){

	/*
	PROPÓSITO: Indica la cantidad de bolitas de color *color*  que se encuentran a *unaDistancia* de la celda actual hacia el *direccion*.
	PRECONDICIONES: Debe haber al menos *unaDistancia* de celdas al *direccion* de la celda actual.
	PARÁMETROS:
	    - color. Color de la bolita a observar.
	    - unaDistancia. Cantidad de celdas que se desplaza el cabezal para observar.
	    - direccion. La dirección de desplazamiento.
	TIPO: Número.
	*/
	
	repeat(unaDistancia){
	    Mover(direccion)
	    
	}
	
	return(nroBolitas(color))


}

function nroDeBolitasDeColor_ADistancia_Al_SiSePuede(color, unaDistancia, direccion){
	/*
	PROPÓSITO: Indica la cantidad de bolitas de color *color*  que se encuentran a *unaDistancia* de la celda actual hacia el *direccion* si se puede, caso contrario devuelve "Fuera de rango". 
	PRECONDICIONES: Ninguna.
	PARÁMETROS:
	    - color. Color de la bolita a observar.
	    - unaDistancia. Cantidad de celdas que se desplaza el cabezal para observar.
	    - direccion. La dirección de desplazamiento.
	TIPO: Número y String.
	*/

    return(choose
    nroDeBolitasDeColor_ADistancia_Al(color, unaDistancia, direccion) when (puedeMover_Al_(unaDistancia,direccion))
    "Fuera de rango" otherwise
	)    
	
	
	
}

function puedeMover_Al_(distancia, direccion){
	/*
	PROPÓSITO:
	PRECONDICIONES:
	PARÁMETROS:
	TIPO:
	*/
	contadorDePasos:= 0
	while (puedeMover(direccion) && contadorDePasos /= distancia){
	    Mover(direccion)
	    contadorDePasos:= contadorDePasos + 1
	}
	return(contadorDePasos == distancia)
}	
	
	
	
	
	